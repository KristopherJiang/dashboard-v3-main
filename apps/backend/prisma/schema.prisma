generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserFunnel {
  id            Int      @id @default(autoincrement())
  registerDate  DateTime @map("register_date") @db.Date
  region        String?  @db.VarChar(64)
  country       String?  @db.VarChar(128)
  retailLayer1  String?  @map("retail_layer1") @db.VarChar(64)
  retailLayer2  String?  @map("retail_layer2") @db.VarChar(64)
  retailLayer3  String?  @map("retail_layer3") @db.VarChar(64)
  userType      String?  @map("user_type") @db.VarChar(64)
  regUserId     Int?     @default(0) @map("reg_user_id")
  regLive7d     Int?     @default(0) @map("reg_live_7d")
  regLiveKyc7d  Int?     @default(0) @map("reg_live_kyc_7d")
  regFtd7d      Int?     @default(0) @map("reg_ftd_7d")
  regFtt7d      Int?     @default(0) @map("reg_ftt_7d")
  regLive30d    Int?     @default(0) @map("reg_live_30d")
  regLiveKyc30d Int?     @default(0) @map("reg_live_kyc_30d")
  regFtd30d     Int?     @default(0) @map("reg_ftd_30d")
  regFtt30d     Int?     @default(0) @map("reg_ftt_30d")

  @@map("user_funnel")
}

model FtdFttConversion {
  id        Int      @id @default(autoincrement())
  ftdDate   DateTime @map("ftd_date") @db.Date
  region    String?  @db.VarChar(64)
  country   String?  @db.VarChar(128)
  ftdUserId Int?     @default(0) @map("ftd_user_id")
  ftdFtt7d  Int?     @default(0) @map("ftd_ftt_7d")

  @@map("ftd_ftt_conversion")
}

model DailyAggregate {
  id            Int      @id @default(autoincrement())
  date          DateTime @db.Date
  region        String?  @db.VarChar(64)
  country       String?  @db.VarChar(128)
  retailLayer1  String?  @map("retail_layer1") @db.VarChar(64)
  retailLayer2  String?  @map("retail_layer2") @db.VarChar(64)
  retailLayer3  String?  @map("retail_layer3") @db.VarChar(64)
  userType      String?  @map("user_type") @db.VarChar(64)
  registerCnt   Int?     @default(0) @map("register_cnt")
  ftdCnt        Int?     @default(0) @map("ftd_cnt")
  fttCnt        Int?     @default(0) @map("ftt_cnt")
  netDeposit    Float?   @default(0) @map("net_deposit")
  tradingVolume Float?   @default(0) @map("trading_volume")

  @@map("daily_aggregates")
}

model FttRetention {
  id          Int      @id @default(autoincrement())
  fttDate     DateTime @map("ftt_date") @db.Date
  region      String?  @db.VarChar(64)
  country     String?  @db.VarChar(128)
  fttUserId   Int?     @default(0) @map("ftt_user_id")
  fttTrade7d  Int?     @default(0) @map("ftt_trade_7d")
  fttTrade30d Int?     @default(0) @map("ftt_trade_30d")

  @@map("ftt_retention")
}

model Region {
  id         Int      @id @default(autoincrement())
  code       String   @unique @db.VarChar(32)
  parentId   Int?     @map("parent_id")
  nameEn     String   @map("name_en") @db.VarChar(128)
  nameCn     String   @map("name_cn") @db.VarChar(128)
  isHot      Boolean  @default(false) @map("is_hot")
  isFavorite Boolean  @default(false) @map("is_favorite")
  sortOrder  Int      @default(0) @map("sort_order")

  parent     Region?  @relation("RegionChildren", fields: [parentId], references: [id])
  children   Region[] @relation("RegionChildren")

  @@map("regions")
}

model ChannelLtv {
  id           Int      @id @default(autoincrement())
  registerDate DateTime @map("register_date") @db.Date
  region       String?  @db.VarChar(64)
  country      String?  @db.VarChar(128)
  retailLayer1 String?  @map("retail_layer1") @db.VarChar(64)
  retailLayer2 String?  @map("retail_layer2") @db.VarChar(64)
  retailLayer3 String?  @map("retail_layer3") @db.VarChar(64)
  userType     String?  @map("user_type") @db.VarChar(64)
  ltv30d       Float?   @default(0) @map("ltv_30d")

  @@map("channel_ltv")
}
